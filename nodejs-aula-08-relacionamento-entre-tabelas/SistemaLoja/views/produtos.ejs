<%- include ('partials/header.ejs') %>
<%- include ('partials/navbar.ejs') %>

    <!-- FORMULARIO DE CADASTRO DE CLIENTES -->
        <div class="container">
            <div class="card">
                <div class="card-header">
                    <h1>Cadastrar Produto</h1>
                </div>
                <div class="card-body">
                    <form action="/produtos/cadastrar" method="POST">
                        <div class="form-group">
                            <label for="nome">Nome do produto:</label>
                            <input type="text" name="nome" id="nome" class="form-control" required>
                        </div>
                        <div class="form-group">
                            <label for="preco">Preço:</label>
                            <input type="number" name="preco" id="preco" class="form-control" required>
                        </div>
                        <div class="form-group">
                            <label for="categoria">Categoria:</label>
                            <input type="text" name="categoria" id="categoria" class="form-control" required>
                        </div>
                        <!-- BOTÕES -->
                        <button type="submit" class="btn btn-success">Cadastrar</button>
                        <button type="reset" class="btn btn-danger">Limpar</button>
                    </form>
                    <hr>
                </div>
            </div>
        </div>


    <div class="container">
        <div class="card">
            <div class="card-header">
                <h1>Produtos</h1>
            </div>
            <div class="card-body">
                <table>
                    <thead>
                        <tr>
                            <th></th>
                            <th>Nome:</th>
                            <th>Preço:</th>
                            <th>Categoria:</th>
                            <th colspan="2" style="text-align: center;">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% produtos.forEach(produto => { %>
                        <tr>
                            <td><img src="imgs/product.png" width="30px"></td>
                            <td><%= produto.nome %></td>
                            <td><%= produto.preco.toLocaleString('pt-br', {style: 'currency', currency: 'BRL'}) %></td>
                            <td><%= produto.categoria %></td>
                            <td>
                                <a href="/produtos/excluir/<%= produto.id %>">
                                    <button onclick="return confirm('Deseja mesmo excluir o produto?')" class="btn btn-danger">
                                        Excluir
                                    </button>
                                </a>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

<%- include ('partials/footer.ejs') %>
